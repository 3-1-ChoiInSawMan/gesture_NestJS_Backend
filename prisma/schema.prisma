// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ───────────────────────────── Enum ─────────────────────────────

enum MessageType {
  text
  file
}

// ───────────────────────────── Models ───────────────────────────

model users {
  idx            BigInt   @id @default(autoincrement())
  email          String   @unique
  nickname       String   @db.VarChar(500)
  id             String   @unique @db.VarChar(200)
  password       String?
  status_message String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  provider       String?  @db.VarChar(200)
  is_deactivated Boolean  @default(false)

  chat_notices          chat_notices[]
  notification_settings notification_settings[]
  quick_slot_presets    quick_slot_presets[]
  rooms                 rooms[]
  room_members          room_members[]
  notifications         notifications[]
  friendships_as_user   friendships[]           @relation("user")
  friendships_as_friend friendships[]           @relation("friend")
  call_participants     call_participants[]
  meetings              meetings[]
  refresh_tokens        refresh_tokens?
  calls                 calls[]
  media                 media[]
  chat_participants     chat_participants[]
  chat_messages         chat_messages[]
}

model chat_rooms {
  idx        BigInt   @id @default(autoincrement())
  name       String   @db.VarChar(1000)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  chat_notices      chat_notices[]
  chat_participants chat_participants[]
  chat_messages     chat_messages[]
}

model chat_notices {
  idx        BigInt   @id @default(autoincrement())
  created_by BigInt
  chat_idx   BigInt
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user      users      @relation(fields: [created_by], references: [idx])
  chat_room chat_rooms @relation(fields: [chat_idx], references: [idx])
}

model notification_settings {
  idx     BigInt  @id @default(autoincrement())
  user_id BigInt
  type    String  @db.VarChar(100)
  is_used Boolean @default(true)

  user users @relation(fields: [user_id], references: [idx])
}

model verification_codes {
  idx        BigInt   @id @default(autoincrement())
  email      String   @db.VarChar(255)
  code       String   @db.VarChar(50)
  created_at DateTime @default(now())
  expires_at DateTime
  is_used    Boolean  @default(false)
}

model quick_actions {
  idx        BigInt   @id @default(autoincrement())
  title      String   @db.VarChar(200)
  emoji_url  String   @db.VarChar(200)
  created_at DateTime @default(now())

  slot_presets_1 quick_slot_presets[] @relation("slot1")
  slot_presets_2 quick_slot_presets[] @relation("slot2")
  slot_presets_3 quick_slot_presets[] @relation("slot3")
  slot_presets_4 quick_slot_presets[] @relation("slot4")
  slot_presets_5 quick_slot_presets[] @relation("slot5")
}

model quick_slot_presets {
  idx         BigInt  @id @default(autoincrement())
  user_idx    BigInt
  action_id_1 BigInt?
  action_id_2 BigInt?
  action_id_3 BigInt?
  action_id_4 BigInt?
  action_id_5 BigInt?

  user     users          @relation(fields: [user_idx], references: [idx])
  action_1 quick_actions? @relation("slot1", fields: [action_id_1], references: [idx])
  action_2 quick_actions? @relation("slot2", fields: [action_id_2], references: [idx])
  action_3 quick_actions? @relation("slot3", fields: [action_id_3], references: [idx])
  action_4 quick_actions? @relation("slot4", fields: [action_id_4], references: [idx])
  action_5 quick_actions? @relation("slot5", fields: [action_id_5], references: [idx])
}

model rooms {
  idx             BigInt   @id @default(autoincrement())
  host_idx        BigInt
  title           String
  description     String?
  max_participant Int
  is_public       Boolean  @default(true)
  password        String?  @db.VarChar(255)
  thumbnail_url   String?  @db.VarChar(255)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  host         users          @relation(fields: [host_idx], references: [idx])
  room_members room_members[]
}

model room_members {
  idx                  BigInt   @id @default(autoincrement())
  room_idx             BigInt
  user_idx             BigInt
  role                 String   @db.VarChar(100)
  last_read_message_id BigInt?
  created_at           DateTime @default(now())

  room rooms @relation(fields: [room_idx], references: [idx])
  user users @relation(fields: [user_idx], references: [idx])
}

model notifications {
  idx        BigInt   @id @default(autoincrement())
  user_idx   BigInt
  target_id  String?  @db.VarChar(100)
  type       String   @db.VarChar(100)
  is_read    Boolean
  content    String
  created_at DateTime @default(now())

  user users @relation(fields: [user_idx], references: [idx])
}

model friendships {
  idx        BigInt   @id @default(autoincrement())
  user_idx   BigInt
  friend_idx BigInt
  accept     Boolean  @default(false)
  not_accept Boolean  @default(false)
  request_at DateTime @default(now())

  user   users @relation("user", fields: [user_idx], references: [idx])
  friend users @relation("friend", fields: [friend_idx], references: [idx])
}

model call_participants {
  idx        BigInt    @id @default(autoincrement())
  user_id    BigInt
  calls_idx  BigInt
  started_by BigInt
  joined_at  DateTime  @default(now())
  left_at    DateTime?
  field      Boolean   @default(false)

  user users @relation(fields: [user_id], references: [idx])
  call calls @relation(fields: [calls_idx], references: [idx])
}

model meetings {
  idx        BigInt   @id @default(autoincrement())
  created_by BigInt
  title      String?  @db.VarChar(100)
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user users @relation(fields: [created_by], references: [idx])
}

model refresh_tokens {
  idx        BigInt   @id @default(autoincrement())
  user_idx   BigInt   @unique
  token      String
  expires_at DateTime

  user users @relation(fields: [user_idx], references: [idx])
}

model calls {
  idx          BigInt    @id @default(autoincrement())
  started_by   BigInt
  is_recording Boolean   @default(false)
  started_at   DateTime  @default(now())
  ended_at     DateTime?

  user              users              @relation(fields: [started_by], references: [idx])
  call_participants call_participants[]
}

model media {
  idx      BigInt  @id @default(autoincrement())
  user_idx BigInt
  file     String?
  url      String  @default(uuid())
  name     String  @db.VarChar(140)

  user          users           @relation(fields: [user_idx], references: [idx])
  chat_messages chat_messages[]
}

model chat_participants {
  idx      BigInt  @id @default(autoincrement())
  chat_idx BigInt
  user_idx BigInt?

  chat_room chat_rooms @relation(fields: [chat_idx], references: [idx])
  user      users?     @relation(fields: [user_idx], references: [idx])
}

model chat_messages {
  idx        BigInt      @id @default(autoincrement())
  sender_idx BigInt
  chat_idx   BigInt
  file_url   BigInt?
  user_idx   BigInt?
  target_idx BigInt?
  message    String?
  is_deleted Boolean     @default(false)
  created_at DateTime    @default(now())
  updated_at DateTime?
  type       MessageType

  sender    users      @relation(fields: [sender_idx], references: [idx])
  chat_room chat_rooms @relation(fields: [chat_idx], references: [idx])
  file      media?     @relation(fields: [file_url], references: [idx])
}
